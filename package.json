{
  "name": "video",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "app": "bun app.tsx",
    "generate:characters": "./generate-character-sheets.sh",
    "generate:keyframes": "./generate-keyframes.sh",
    "status:checklist": "bun render-status-checklist.ts",
    "validate:data": "bun validate-workflow-data.ts",
    "typecheck": "tsc --noEmit --pretty",
    "format": "prettier --write .",
    "reset": "bun reset-history.ts",
    "reset:all": "rm -f .history.json",
    "reset:hard": "rm -rf workspace/ .history.json && mkdir workspace/ && echo '' > workspace/.gitkeep"
  },
  "devDependencies": {
    "@types/react": "^19.2.2",
    "@types/bun": "latest",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "prettier-plugin-tailwindcss": "^0.7.2"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@opentui/core": "^0.1.87",
    "@opentui/react": "^0.1.87",
    "arg": "^5.0.2",
    "ai": "^6.0.116",
    "openai": "^6.27.0",
    "react": "^19.2.0",
    "ws": "^8.18.3",
    "zod": "^4.3.6"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "trailingComma": "all",
    "arrowParens": "always",
    "semi": false,
    "organizeImportsSkipDestructiveCodeActions": true,
    "plugins": [
      "prettier-plugin-organize-imports",
      "prettier-plugin-tailwindcss"
    ]
  }
}
